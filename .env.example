# ── Postgres ──────────────────────────────────────────
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=change_me_strong_password

# ── n8n ──────────────────────────────────────────────
# Generate with: openssl rand -hex 16
N8N_ENCRYPTION_KEY=change_me_32char_random_string
N8N_HOST=localhost
N8N_PROTOCOL=http
# Local: keep the line below. On Railway: set this to your PUBLIC n8n URL
# WITH a trailing slash, e.g. https://recap-n8n.up.railway.app/
# (n8n bakes this into the registered webhook URLs, so it must be reachable.)
WEBHOOK_URL=http://localhost:5678/
TIMEZONE=Asia/Kuala_Lumpur
# Generate AFTER first boot: n8n UI → Settings → n8n API → Create API key
# Then run: docker compose --profile init up n8n-init
N8N_API_KEY=

# ── Anthropic ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# Optional — override the model the workflow uses. Defaults to a stable
# Sonnet snapshot. Change only if your key lacks access to the default.
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# ── Notion ────────────────────────────────────────────
NOTION_API_KEY=secret_...

# ── SendGrid ──────────────────────────────────────────
SENDGRID_API_KEY=SG....
SENDGRID_FROM_EMAIL=your@email.com

# ── Supabase ──────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Frontend → n8n webhook ────────────────────────────
# The browser calls the frontend's own /api/recap/* routes (same-origin),
# which proxy to n8n server-to-server — so there is NO browser CORS to deal with.
#
# N8N_WEBHOOK_URL is what the proxy uses (server-side). In Docker Compose it
# must use the n8n SERVICE NAME, not localhost:
N8N_WEBHOOK_URL=http://n8n:5678/webhook/recap
# On Railway, set N8N_WEBHOOK_URL to your n8n service's URL, e.g.
# https://recap-n8n.up.railway.app/webhook/recap
#
# NEXT_PUBLIC_N8N_WEBHOOK_URL is kept only as a fallback; the browser no longer
# uses it directly. Safe to leave as-is.
NEXT_PUBLIC_N8N_WEBHOOK_URL=http://localhost:5678/webhook/recap
